          <datasource-dependencies datasource='federated.0mg5h581glawp71akunoh1monruf'>
            <column caption='% Diff Sales per Customer' datatype='real' datatype-customized='true' default-format='p0.0%' name='[% Diff Customers (copy)_2164195833790491]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF ISNULL([CY Sales per Customer (copy)_2164195834945565]) OR [CY Sales per Customer (copy)_2164195834945565] = 0&#10;THEN NULL&#10;ELSE ([Calculation_2164195831746585] - [CY Sales per Customer (copy)_2164195834945565])/ [CY Sales per Customer (copy)_2164195834945565]&#10;END' />
